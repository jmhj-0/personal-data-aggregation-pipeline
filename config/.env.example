# Steam
STEAM_API_KEY=your_steam_api_key_here
STEAM_ID=your_steam_id_here

# MyAnimeList
MAL_CLIENT_ID=your_mal_client_id_here
MAL_USERNAME=your_mal_username_here

# Spotify
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token_here

# Goodreads (public profile, no API key needed)
GOODREADS_USER_ID=your_goodreads_user_id_here

# GitHub
GH_PAT=your_github_personal_access_token_here
GH_USERNAME=your_github_username_here

# X (Twitter) — requires Basic tier or above on X Developer Platform
X_BEARER_TOKEN=your_x_bearer_token_here
X_USERNAME=your_x_username_here
